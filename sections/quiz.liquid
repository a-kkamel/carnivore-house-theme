{% javascript %}
jQuery('input.btn.quizbutton').click(function(e){
e.preventDefault()
  
var val = jQuery('input[name="customer[answer1]"]:checked').val();
if(val == undefined){
  val = 0;
  $(".tab-pane .next").attr("disabled")
}else{
  $(".tab-pane .next").removeAttr("disabled")
}
 var val2 = jQuery('input[name="customer[answer2]"]:checked').val(); 
var val3 = jQuery('input[name="customer[answer3]"]:checked').val(); 
var val4 = jQuery('input[name="customer[answer4]"]:checked').val(); 
var val5 = jQuery('input[name="customer[answer5]"]:checked').val(); 
var val6 = jQuery('input[name="customer[answer6]"]:checked').val(); 
if(val2 == undefined){
  val2 = 0;
}
if(val3 == undefined){
  val3 = 0;
  
}
if(val4 == undefined){
  val4 = 0;
}
if(val5 == undefined){
  val5 = 0;
}
if(val6 == undefined){
  val6 = 0;
}
var sum = parseInt(val)+parseInt(val2)+parseInt(val3)+parseInt(val4)+parseInt(val5)+parseInt(val6);
jQuery('.score').val(sum);
console.log(sum)

var email = jQuery('input.email').val();
if(email == ''){
  jQuery(".error-message").show();
  jQuery('.input-error-message').text("Email is required");
}else{
 jQuery('#CustomerAccount').submit();
}

})
if($( ".form-message" ).hasClass( "form-message--success" )){
$(".showback").show();
$(".formhide").hide();
}

$('#step1').addClass('in active');

$('.next').click(function(){

  var nextId = $(this).parents('.tab-pane').next().attr("id");
  console.log(nextId);
  $('[href="#'+nextId+'"]').tab('show');
  return false;
  
})
$('.previous').click(function(){

  var pId = $(this).parents('.tab-pane').prev().attr("id");
  console.log(pId);
  $('[href="#'+pId+'"]').tab('show');
  return false;
  
})
$('a[data-toggle="tab"]').on('shown.bs.tab', function (e) {
  
  //update progress
  var step = $(e.target).data('step');
  var percent = (parseInt(step) / 7) * 100;
  
  $('.progress-bar').css({width: percent + '%'});
  $('.progress-bar').text("Step " + step + " of 7");
  
  //e.relatedTarget // previous tab
  
})

$('.first').click(function(){

  $('#myWizard a:first').tab('show')

})
