{% schema %}
{
	"blocks": [
		{
			"name": "Quiz Heading",
			"type": "FAQHeading",
			"limit": 1,
			"settings": [
				{
					"type": "text",
					"id": "faqHeading",
					"label": "Quiz Title",
					"default": "Quiz"
				}
			]
		},
		
		{
			"name": "Quiz Q and A",
			"type": "faqQandA",
			"settings": [
                {
                  "type": "image_picker",
                  "id": "qimage",
                  "label": "Image"
                },
	            {
	                "type": "text",
	                "label": "Enter Question",
	                "id": "faqQuestion",
	                "default": "Quiz question content goes here"
	            },
	            {
	                "type": "textarea",
	                "label": "Enter Answer",
	                "id": "faqAnswer1",
	                "default": "Lorem ipsum dolor amit icit"
	            },
	            {
	                "type": "textarea",
	                "label": "Enter Answer 2",
	                "id": "faqAnswer2",
	                "default": "Lorem ipsum dolor amit icit"
	            }
				,
	            {
	                "type": "textarea",
	                "label": "Enter Answer 3",
	                "id": "faqAnswer3",
	                "default": "Lorem ipsum dolor amit icit"
	            }
				,
	            {
	                "type": "textarea",
	                "label": "Enter Answer 4",
	                "id": "faqAnswer4",
	                "default": "Lorem ipsum dolor amit icit"
	            }
				,
	            {
	                "type": "textarea",
	                "label": "Enter Answer 5",
	                "id": "faqAnswer5",
	                "default": "Lorem ipsum dolor amit icit"
	            }
			]
		}
	]
}
{% endschema %}
