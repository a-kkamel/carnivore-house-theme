{% assign is_b2b = false %}
{% for tag in customer.tags %}
  {% if tag == 'wholesale' or tag == 'b2b' %}
    {% assign is_b2b = true %}
  {% endif %}
{% endfor %}

{% if customer %}
  {% if is_b2b %}
    {% render 'b2b-hero' %}
    {% render 'b2b-catalog' %}
  {% else %}
    <div class="b2b-pending">
      <div class="b2b-pending__inner">
        <div class="b2b-pending__icon">⏳</div>
        <h2>Application Pending</h2>
        <p>Your wholesale account is under review. We'll notify you at <strong>{{ customer.email }}</strong> once approved — typically within 1–2 business days.</p>
        <a href="{{ routes.root_url }}" class="b2b-btn">Back to Store</a>
      </div>
    </div>
  {% endif %}
{% else %}
  <script>
    window.location.href = '{{ routes.account_login_url }}?return_url={{ request.path | url_encode }}';
  </script>
  <noscript>
    <p>Please <a href="{{ routes.account_login_url }}?return_url={{ request.path | url_encode }}">log in</a> to access the wholesale portal.</p>
  </noscript>
{% endif %}

<style>
.b2b-pending {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #0a0a0a;
  color: #fff;
  font-family: 'Georgia', serif;
}
.b2b-pending__inner {
  text-align: center;
  max-width: 480px;
  padding: 3rem 2rem;
}
.b2b-pending__icon { font-size: 3rem; margin-bottom: 1rem; }
.b2b-pending h2 { font-size: 2rem; margin-bottom: 1rem; color: #c9a96e; }
.b2b-pending p { color: #aaa; line-height: 1.7; margin-bottom: 2rem; font-family: sans-serif; }
.b2b-pending a { color: #c9a96e; }
.b2b-btn {
  display: inline-block;
  padding: 0.8rem 2rem;
  background: #c9a96e;
  color: #0a0806;
  text-decoration: none;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  font-size: 0.85rem;
  font-family: sans-serif;
}
</style>

